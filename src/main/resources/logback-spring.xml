<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logging baseline (M1a). Goal: fast exception debugging.
  - Console pattern includes a per-request correlation id (MDC key "requestId",
    set by RequestIdFilter) so all log lines for one request are greppable.
  - "dev" profile: app package at DEBUG, full stack traces.
  - default/other profiles: app package at INFO.
  Extends Spring Boot's own defaults via base.xml (colors, sane framework levels).
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] [req=%X{requestId:-}] %logger{36} - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Application logs: DEBUG in dev, INFO otherwise -->
    <springProfile name="dev">
        <logger name="com.arthvritt.platform" level="DEBUG"/>
        <!-- Uncomment to see SQL while debugging:
        <logger name="org.hibernate.SQL" level="DEBUG"/>
        <logger name="org.hibernate.orm.jdbc.bind" level="TRACE"/>
        -->

        <!-- Dev-only: mirror all logs to a file so a full startup can be inspected/analysed after the fact.
             logs/ is git-ignored. Rolls at 10MB, keeps 7 days / 200MB. (A custom logback config overrides
             Spring Boot's logging.file.name, so the file appender must be declared here, not in properties.) -->
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/backend-dev.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>logs/backend-dev-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <maxHistory>7</maxHistory>
                <totalSizeCap>200MB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>
        <root>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <springProfile name="!dev">
        <logger name="com.arthvritt.platform" level="INFO"/>
    </springProfile>
</configuration>
